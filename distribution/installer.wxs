; ============================================================================
; WiX Toolset 安装脚本 - 生成 MSI 安装程序
; 适用于 SolidWorks Plugin & Tools
; ============================================================================

<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" 
           Name="MyTools - SolidWorks Plugin and Utilities" 
           Language="1033" 
           Version="1.0.0" 
           Manufacturer="YourCompany"
           UpgradeCode="{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}">
    
    <Package InstallerVersion="200" 
             Compressed="yes" 
             InstallScope="perMachine"
             Description="SolidWorks 插件和命令行工具集"
             Comments="包含 Python 工具和 C# 工具"/>
    
    <MajorUpgrade DowngradeErrorMessage="已安装更新版本，请先卸载后再安装。"/>
    <MediaTemplate EmbedCab="yes"/>
    
    <!-- 功能定义 -->
    <Feature Id="Complete" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="PathComponent" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>
    
    <!-- 自定义操作：注册 SolidWorks 插件 -->
    <CustomAction Id="RegisterPlugin" 
                  Directory="INSTALLFOLDER"
                  Execute="defered"
                  Impersonate="no"
                  Return="check"
                  ExeCommand="[SYSFolder]cmd.exe /c &quot;&quot;[INSTALLFOLDER]register_plugin.bat&quot;&quot;" />
    
    <CustomAction Id="UnregisterPlugin" 
                  Directory="INSTALLFOLDER"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  ExeCommand="[SYSFolder]cmd.exe /c &quot;&quot;[INSTALLFOLDER]unregister_plugin.bat&quot;&quot;" />
    
    <InstallExecuteSequence>
      <Custom Action="RegisterPlugin" After="InstallFiles">NOT Installed</Custom>
      <Custom Action="UnregisterPlugin" Before="RemoveFiles">REMOVE="ALL"</Custom>
    </InstallExecuteSequence>
    
    <!-- UI 设置 -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <UIRef Id="WixUI_InstallDir" />
    <UIRef Id="WixUI_ErrorProgressText" />
    
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="MyTools" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="StartMenuPrograms" Name="MyTools" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      
      <!-- Plugin 文件 -->
      <Component Id="PluginFiles" Guid="{11111111-1111-1111-1111-111111111111}">
        <File Source="$(var.PluginDir)\plugin.dll" KeyPath="yes"/>
        <File Source="$(var.PluginDir)\plugin.pdb"/>
        <File Source="$(var.PluginDir)\welcome.png"/>
        <File Source="$(var.PluginDir)\solidworkstools.dll"/>
        <File Source="$(var.PluginDir)\SolidWorks.Interop.sldworks.dll"/>
        <File Source="$(var.PluginDir)\SolidWorks.Interop.swconst.dll"/>
        <File Source="$(var.PluginDir)\SolidWorks.Interop.swpublished.dll"/>
      </Component>
      
      <!-- CTools 文件 -->
      <Component Id="CToolsFiles" Guid="{22222222-2222-2222-2222-222222222222}">
        <File Source="$(var.CToolsDir)\ctool.exe" KeyPath="yes"/>
        <File Source="$(var.CToolsDir)\ctool.pdb"/>
        <File Source="$(var.CToolsDir)\ctool.deps.json"/>
        <File Source="$(var.CToolsDir)\ctool.runtimeconfig.json"/>
        <File Source="$(var.CToolsDir)\share.dll"/>
        <File Source="$(var.CToolsDir)\Autodesk.AutoCAD.Interop.dll"/>
        <File Source="$(var.CToolsDir)\Autodesk.AutoCAD.Interop.Common.dll"/>
      </Component>
      
      <!-- Python Tools 文件 -->
      <Component Id="PythonToolsFiles" Guid="{33333333-3333-3333-3333-333333333333}">
        <File Source="$(var.PythonToolsDir)\ptool.exe" KeyPath="yes"/>
        <File Source="$(var.PythonToolsDir)\main.py"/>
        <File Source="$(var.PythonToolsDir)\__init__.py"/>
        <File Source="$(var.PythonToolsDir)\command_search.py"/>
        <!-- 添加其他 Python 模块文件 -->
      </Component>
      
      <!-- 注册/卸载脚本 -->
      <Component Id="Scripts" Guid="{44444444-4444-4444-4444-444444444444}">
        <File Source="register_plugin.bat" KeyPath="yes"/>
        <File Source="unregister_plugin.bat"/>
        <File Source="tools.bat"/>
      </Component>
      
    </ComponentGroup>
    
    <!-- PATH 环境变量组件 -->
    <Component Id="PathComponent" Guid="{55555555-5555-5555-5555-555555555555}" KeyPath="yes">
      <Environment Id="PATH" 
                   Name="PATH" 
                   Value="[INSTALLFOLDER]" 
                   Permanent="no" 
                   Part="last" 
                   Action="set" 
                   System="yes"/>
    </Component>
    
    <!-- 开始菜单快捷方式 -->
    <Component Id="StartMenuShortcut" Guid="{66666666-6666-6666-6666-666666666666}">
      <Shortcut Id="StartMenuMyTools" 
                Name="MyTools CMD" 
                Target="cmd.exe" 
                Arguments="/k cd /d &quot;[INSTALLFOLDER]&quot;"
                WorkingDirectory="INSTALLFOLDER"
                Description="打开 MyTools 命令行窗口"/>
      
      <Shortcut Id="StartMenuUninstall" 
                Name="卸载 MyTools" 
                Target="[System64Folder]msiexec.exe" 
                Arguments="/x [ProductCode]"
                Description="卸载 MyTools"/>
      
      <RemoveFolder Id="CleanStartMenu" On="uninstall"/>
      <RegistryValue Root="HKCU" 
                     Key="Software\MyCompany\MyTools" 
                     Name="installed" 
                     Type="integer" 
                     Value="1" 
                     KeyPath="yes"/>
    </Component>
    
  </Fragment>
</Wix>
